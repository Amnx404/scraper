# Copy to `.env` in this directory (repo root) and fill in values.
# `prepare_ingestion.py` and `upsert_pinecone.py` load `.env` via python-dotenv when run from the CLI.
# The FastAPI app (`app/main.py`) does not load this file; set variables in the process environment
# (e.g. Railway dashboard) or export them before `uvicorn`.
#
# Pinecone namespace prefix + staging name are passed on POST /upload in the JSON body, not here.

# -----------------------------------------------------------------------------
# Postgres — required for POST /runs (Procrastinate background pipeline)
# -----------------------------------------------------------------------------
# libpq URL, e.g. postgresql://user:pass@host:5432/dbname
# Railway/Heroku often provide postgres://… — the app normalizes that to postgresql://.
DATABASE_URL=
#
# After setting DATABASE_URL, install the queue tables once (use dots, not a colon, before the app object):
#   uv sync   # or: pip install -r requirements.txt
#   procrastinate --app=live.worker.app.procrastinate_app schema --apply
# Run a worker (separate process from uvicorn):
#   procrastinate --app=live.worker.app.procrastinate_app worker

# -----------------------------------------------------------------------------
# Pinecone — required for POST /upload (upsert_pinecone.py)
# -----------------------------------------------------------------------------
PINECONE_API_KEY=
# Host URL from Pinecone console (index), e.g. https://xxxx.svc.region.pinecone.io
PINECONE_INDEX_HOST=

# -----------------------------------------------------------------------------
# OpenRouter — optional defaults for CLI; API uses request body for finetune
# -----------------------------------------------------------------------------
# Used as the LLM API key when POST /prepare has finetune: true and openrouter_api_key is omitted.
OPENROUTER_API_KEY=

# Optional CLI default for prepare_ingestion (FINETUNE_MODEL overrides when set on the request).
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Optional OpenRouter attribution (defaults are fine for local use)
# FINETUNE_HTTP_REFERER=https://github.com/
# FINETUNE_X_TITLE=prepare_ingestion

# -----------------------------------------------------------------------------
# Crawl4AI — required for the crawl4ai engine (default scrape engine)
# -----------------------------------------------------------------------------
# Base URL of the Crawl4AI deployment (no trailing slash)
CRAWL4AI_BASE_URL=https://crawl4ai-production-896f.up.railway.app
# Bearer token for Crawl4AI API authentication
CRAWL4AI_API_TOKEN=

# -----------------------------------------------------------------------------
# Browserless — only needed when page_fetcher=browserless
# -----------------------------------------------------------------------------
# Full URL including token query param, e.g. https://chrome.browserless.io/content?token=…
BROWSERLESS_CONTENT_URL=
